{
  "name": "ppt_generate",
  "description": "Compatibility fallback: generate a PowerPoint (.pptx) presentation. Prefer `run_shell` + `doc-script-editor` (`create_pptx`, `validate`, `render` for slide-image QA, and `unpack`/`pack` for template/OOXML edits) for serious decks, speaker notes, templates, validation, or follow-up edits. Use this frontend-rendered pptxgenjs tool only when Python is unavailable or the deck is simple enough for the structured schema. Provide a path where the file should be saved, and a deck specification with a theme, title, and an array of slides. Each slide has a 'layout' discriminator (title | agenda | body | two_column | stat | quote | section | image_full) and layout-specific fields. The actual PPTX rendering happens in the desktop frontend via pptxgenjs, not in Rust.",
  "parameters": {
    "type": "object",
    "required": ["path", "spec"],
    "properties": {
      "path": {
        "type": "string",
        "description": "Absolute file path where the .pptx should be saved. Must end in .pptx. Must be inside a user-registered source directory."
      },
      "spec": {
        "type": "object",
        "required": ["title", "slides"],
        "properties": {
          "title": { "type": "string", "description": "Deck title, used on the title slide and as the file metadata title." },
          "subtitle": { "type": "string" },
          "author": { "type": "string" },
          "theme": {
            "description": "Theme name ('nexa-light' | 'nexa-dark') or inline theme object.",
            "oneOf": [
              { "type": "string", "enum": ["nexa-light", "nexa-dark"] },
              {
                "type": "object",
                "properties": {
                  "primary_color": { "type": "string", "description": "Hex without #, e.g. '14B8A6'" },
                  "accent_color":  { "type": "string" },
                  "background_color": { "type": "string" },
                  "text_color": { "type": "string" },
                  "title_color": { "type": "string" },
                  "title_font": { "type": "string" },
                  "body_font":  { "type": "string" }
                }
              }
            ]
          },
          "slides": {
            "type": "array",
            "minItems": 1,
            "description": "Ordered list of slides. Each slide must have a 'layout' field matching one of the supported layouts.",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["layout", "title"],
                  "properties": {
                    "layout": { "const": "title" },
                    "title": { "type": "string" },
                    "subtitle": { "type": "string" },
                    "author": { "type": "string" },
                    "image_url": { "type": "string", "description": "Optional background image URL." }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "items"],
                  "properties": {
                    "layout": { "const": "agenda" },
                    "title": { "type": "string", "description": "Defaults to 'Agenda'" },
                    "items": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "title"],
                  "properties": {
                    "layout": { "const": "body" },
                    "title": { "type": "string" },
                    "bullets": { "type": "array", "items": { "type": "string" } },
                    "paragraph": { "type": "string", "description": "Use instead of bullets for prose-style content." },
                    "image_url": { "type": "string" },
                    "image_caption": { "type": "string" }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "title", "left", "right"],
                  "properties": {
                    "layout": { "const": "two_column" },
                    "title": { "type": "string" },
                    "left":  { "type": "object", "properties": { "heading": { "type": "string" }, "bullets": { "type": "array", "items": { "type": "string" } }, "image_url": { "type": "string" }, "paragraph": { "type": "string" } } },
                    "right": { "type": "object", "properties": { "heading": { "type": "string" }, "bullets": { "type": "array", "items": { "type": "string" } }, "image_url": { "type": "string" }, "paragraph": { "type": "string" } } }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "stats"],
                  "properties": {
                    "layout": { "const": "stat" },
                    "title": { "type": "string" },
                    "stats": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 4,
                      "items": {
                        "type": "object",
                        "required": ["value", "label"],
                        "properties": {
                          "value": { "type": "string" },
                          "label": { "type": "string" },
                          "caption": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "text"],
                  "properties": {
                    "layout": { "const": "quote" },
                    "text": { "type": "string" },
                    "attribution": { "type": "string" }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "title"],
                  "properties": {
                    "layout": { "const": "section" },
                    "title": { "type": "string" },
                    "subtitle": { "type": "string" }
                  }
                },
                {
                  "type": "object",
                  "required": ["layout", "image_url"],
                  "properties": {
                    "layout": { "const": "image_full" },
                    "title": { "type": "string" },
                    "image_url": { "type": "string" },
                    "caption": { "type": "string" }
                  }
                }
              ]
            }
          },
          "notes_per_slide": {
            "type": "array",
            "description": "Optional parallel array of speaker notes, one per slide (same index).",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
